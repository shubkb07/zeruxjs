{
  "name": "zeruxjs-app",
  "version": "1.0.0",
  "description": "ZeruxJS Sample Application",
  "author": "Shubham Kumar Bansal",
  "type": "module",
  "main": "index.js",
  "dependencies": {
    "@zeruxjs/db": "*",
    "zeruxjs": "*",
    "sample-module": "*",
    "sample-os": "*",
    "@zeruxjs/typescript": "*"
  },
  "private": true,
  "scripts": {
    "build": "zerux build",
    "dev": "zerux dev -p 3010",
    "start": "zerux start",
    "meow": "zerux meow",
    "ds:start": "SESSION=$(node -p \"require('./package.json').name.replace(/[@/]/g,'-')\") && tmux has-session -t \"$SESSION\" 2>/dev/null || tmux new-session -d -s \"$SESSION\" \"npm run start\"",
    "de:start": "SESSION=$(node -p \"require('./package.json').name.replace(/[@/]/g,'-')\") && tmux kill-session -t \"$SESSION\" 2>/dev/null || true",
    "ds:dev": "SESSION=$(node -p \"require('./package.json').name.replace(/[@/]/g,'-')\") && tmux has-session -t \"$SESSION\" 2>/dev/null || tmux new-session -d -s \"$SESSION\" \"npm run dev\"",
    "de:dev": "SESSION=$(node -p \"require('./package.json').name.replace(/[@/]/g,'-')\") && tmux kill-session -t \"$SESSION\" 2>/dev/null || true"
  },
  "homepage": "https://github.com/zeruxjs/zeruxjs#readme",
  "bugs": {
    "url": "https://github.com/zeruxjs/zeruxjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeruxjs/zeruxjs.git"
  },
  "license": "(MIT OR Apache-2.0)",
  "types": "./dist/index.d.ts",
  "keywords": [
    "ZeruxJS Sample Application"
  ]
}